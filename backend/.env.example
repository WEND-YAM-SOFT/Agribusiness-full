MONGODB_URI=mongodb://127.0.0.1:27017/agribusiness
JWT_SECRET=change_this_secret

# SMTP configuration for real password reset emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@example.com
SMTP_PASS=change_this_password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=AgriBusiness
SMTP_REPLY_TO=support@example.com

# Optional public URL used to build clickable reset links in the email
# Example Flutter web route: http://localhost:8090/#/reset-password
PASSWORD_RESET_URL=http://localhost:8090/#/reset-password
APP_WEB_URL=http://localhost:8090
